.webassets-cache

# ==============================
# Scrapy 爬虫框架缓存
# ==============================
# 爬虫运行日志、爬取缓存目录
.scrapy

# ==============================
# Sphinx 静态文档构建产物（区别mkdocs）
# ==============================
# Sphinx编译生成的静态网页目录
docs/_build/

# ==============================
# PyBuilder 项目构建工具输出目录
# ==============================
# 构建产物、测试输出文件夹
target/

# ==============================
# Jupyter Notebook 笔记缓存
# ==============================
