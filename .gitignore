ipython_config.py

# ==============================
# pyenv Python多版本管理
# ==============================
# 本地指定Python版本标记文件
.python-version

# ==============================
# Pipenv 虚拟环境工具
# ==============================
# 官方建议Pipfile.lock提交仓库，注释关闭忽略
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# ==============================
# PEP 582 本地项目依赖包标准
# ==============================
# 项目本地依赖存放目录
__pypackages__/

# ==============================
# Celery 异步任务队列缓存
# ==============================
# 定时任务调度记录文件
celerybeat-schedule
# celery进程PID文件
celerybeat.pid

# ==============================
# SageMath 数学工具解析缓存
# ==============================
*.sage.py

# ==============================
# 各类Python虚拟环境目录（体积巨大，必忽略）
# ==============================
# 本地环境变量配置（可存放密钥，禁止上传）
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

