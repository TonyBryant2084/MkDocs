# ==============================
# Python 字节编译/优化/动态链接缓存文件
# ==============================
# Python运行py文件自动生成的字节码缓存文件夹，加速重复运行，无需提交
__pycache__/
# .pyc/.pyo/.pyd 编译字节码文件通配匹配
*.py[cod]
# Jython 对应的Java class缓存文件
*$py.class

# ==============================
# C语言扩展编译产物（Linux/macOS平台）
# ==============================
# C扩展模块编译后的动态库文件
*.so

# ==============================
# Python 库打包/分发构建产物
# ==============================
# 虚拟环境标识文件
.Python
# setuptools打包构建临时目录
build/
# 开发模式egg缓存目录
develop-eggs/
# 打包输出目录，存放whl/tar.gz安装包
dist/
# 依赖下载缓存目录
downloads/
# egg格式依赖包目录
eggs/
.eggs/
# 打包生成的库文件目录
lib/
lib64/
# 打包过程临时部件目录
parts/
# 源码分发包输出目录
sdist/
# 打包版本变量缓存
var/
# whl格式安装包存放目录
wheels/
# pip依赖元数据文件夹
pip-wheel-metadata/
# 系统共享python wheel缓存
share/python-wheels/
# 包元信息文件夹，打包自动生成
*.egg-info/
# 包安装记录配置文件
.installed.cfg
# egg格式依赖包文件
*.egg
# 打包自动生成的清单文件
MANIFEST

# ==============================
# PyInstaller 打包EXE/二进制程序相关文件
# ==============================
# 打包前自动生成的清单文件
*.manifest
# PyInstaller打包项目配置文件
*.spec

# ==============================
# pip安装日志文件
# ==============================
# pip运行日志
pip-log.txt
# pip自动生成的目录删除标记文件
pip-delete-this-directory.txt

# ==============================
# 单元测试/覆盖率报告缓存
# ==============================
# 网页版覆盖率报告文件夹
htmlcov/
# tox多版本测试虚拟环境目录
.tox/
# nox多环境测试缓存
.nox/
# 覆盖率统计数据文件
.coverage
.coverage.*
# 你的mkdocs流水线依赖缓存目录，本地无需上传
.cache
# nosetest测试报告
nosetests.xml
# coverage工具标准xml报告
coverage.xml
# 覆盖率分段记录文件
*.cover
# 逗号分隔覆盖率缓存
*.py,cover
# hypothesis测试用例缓存
.hypothesis/
# pytest测试框架缓存文件夹
.pytest_cache/

# ==============================
# 国际化翻译编译文件
# ==============================
